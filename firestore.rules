rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Chỉ user đã đăng nhập (ẩn danh) mới đọc/ghi — bật Anonymous Auth trên Firebase Console.
    match /checklistResults/{id} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
    }
    match /checklistUniqueness/{id} {
      allow read, create, delete: if request.auth != null;
    }
    // Bộ đếm số văn bản PDF (001/CL-CNTTDL, …) — chỉ ghi qua transaction khi nộp checklist.
    match /checklistCounters/{id} {
      allow read, create, update: if request.auth != null;
    }
  }
}
