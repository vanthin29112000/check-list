# Copy thành file `.env` ở gốc repo (cùng cấp netlify.toml).
# Netlify CLI (`netlify dev`, `netlify functions:serve`) nạp file này cho Functions — KHÔNG đọc checklist-react/.env.

# --- Gửi mail — function send-checklist-notification (ưu tiên SMTP nếu đủ 3 biến; không thì dùng Resend) ---
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-mailbox@your-domain.edu.vn
SMTP_PASS=
SMTP_FROM="Checklist <your-mailbox@your-domain.edu.vn>"
# Hoặc Resend (không cần SMTP_*): https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM="Checklist <onboarding@resend.dev>"

# Tuỳ chọn: nếu đặt, app phải gửi cùng giá trị qua Authorization Bearer (đặt VITE_NOTIFY_SHARED_SECRET trong checklist-react).
NOTIFY_SHARED_SECRET=
# JSON service account (một dòng) — chỉ cần cho script xoá dữ liệu Firestore (functions/scripts), không dùng cho gửi mail.
FIREBASE_SERVICE_ACCOUNT_JSON=
PUBLIC_BASE_URL=http://localhost:8888
# Lãnh đạo — email nhận bản có link duyệt + dashboard (ví dụ: Nguyễn Hoàng Bảo Trung)
LEADER_EMAILS=
# Nhân sự — cùng nội dung mail với lãnh đạo; nhiều địa chỉ: phân tách bằng dấu phẩy
HR_EMAILS=
# Tuỳ chọn — tương thích cũ; gộp chung với hai dòng trên (không trùng email)
MANAGER_EMAILS=
# Tên lãnh đạo in trên PDF (mặc định Nguyễn Hoàng Bảo Trung nếu để trống)
PDF_LEADER_NAME=
ERROR_THRESHOLD=5
CORS_ORIGINS=http://localhost:5173,http://localhost:8888
