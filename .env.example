# Copy thành file `.env` ở gốc repo (cùng cấp netlify.toml).
# Netlify CLI (`netlify dev`, `netlify functions:serve`) nạp file này cho Functions — KHÔNG đọc checklist-react/.env.

RESEND_API_KEY=
RESEND_FROM="Checklist <onboarding@resend.dev>"
# Chưa verify domain: Resend chỉ gửi được tới email tài khoản Resend. Đặt = email đó → mọi thư chuyển vào inbox này (tiêu đề/nội dung ghi người nhận thật). Có domain + RESEND_FROM đúng domain thì xóa dòng này.
# RESEND_SANDBOX_FORWARD_TO=ban@gmail.com
# Bắt buộc: toàn bộ file JSON service account trên MỘT dòng (minify), không có xuống dòng
FIREBASE_SERVICE_ACCOUNT_JSON=
PUBLIC_BASE_URL=http://localhost:8888
MANAGER_EMAILS=
ERROR_THRESHOLD=5
CORS_ORIGINS=http://localhost:5173,http://localhost:8888
