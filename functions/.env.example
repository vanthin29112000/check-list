# Copy to .env for Firebase emulator (optional). Set the same keys in:
# Firebase Console > Functions > configuration (or Secret Manager for production).

# Public URL of the API (used in approval links in emails). Example after deploy:
# https://your-site.web.app
PUBLIC_BASE_URL=http://127.0.0.1:5000

# SMTP — if SMTP_HOST is empty, emails are only logged to the console.
SMTP_HOST=
SMTP_PORT=587
SMTP_USE_SSL=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# LEADER_EMAILS + HR_EMAILS + MANAGER_EMAILS (legacy): nhận mail duyệt / cảnh báo; gộp, không trùng.
LEADER_EMAILS=
HR_EMAILS=
MANAGER_EMAILS=
PDF_LEADER_NAME=
ERROR_THRESHOLD=5
