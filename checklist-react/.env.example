# Firebase Web SDK (public — không phải secret)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# URL công khai của site (dùng cho link duyệt; có thể bỏ trống để dùng origin trình duyệt)
# VITE_PUBLIC_BASE_URL=https://your-site.netlify.app

# Chỉ `npm run dev`: URL function deploy — app gọi `/.netlify/functions/...` cùng origin, Vite proxy tới URL này (tránh CORS "Failed to fetch")
# VITE_NOTIFY_FUNCTION_URL=https://your-site.netlify.app/.netlify/functions/send-checklist-notification
#
# Hoặc gốc repo `npm run dev` → mở http://localhost:8888 (SMTP + tuỳ chọn NOTIFY_SHARED_SECRET trong `.env` gốc repo).
# Hoặc hai terminal: gốc `npm run dev:functions` + đây `npm run dev`, khi đó mới bật VITE_NETLIFY_DEV_PROXY=1 (nếu bật mà không chạy :8888 sẽ lỗi 500).

# Tuỳ chọn: trùng NOTIFY_SHARED_SECRET ở `.env` gốc repo (lộ trong bundle — chỉ dùng nếu chấp nhận).
# VITE_NOTIFY_SHARED_SECRET=

# --- Chỉ đặt trên Netlify (Site → Environment variables), KHÔNG dùng prefix VITE_ ---
# (Local: copy sang file `.env` ở gốc repo — xem `.env.example` ở gốc repo.)
# SMTP_* — xem `.env.example` gốc repo. Function gửi mail không dùng Firebase Admin.
# FIREBASE_SERVICE_ACCOUNT_JSON chỉ cho script xoá dữ liệu (functions/scripts), không bắt buộc cho mail.
# PUBLIC_BASE_URL=https://your-site.netlify.app
# Nhiều email: cách nhau bằng dấu phẩy, không bọc từng email trong ngoặc kép
# LEADER_EMAILS=lãnhđạo@example.com
# HR_EMAILS=ns1@example.com,ns2@example.com
# MANAGER_EMAILS=quanly1@example.com (tuỳ chọn, tương thích cũ)
# PDF_LEADER_NAME=Nguyễn Hoàng Bảo Trung
# ERROR_THRESHOLD=5
# CORS_ORIGINS=https://your-site.netlify.app,http://localhost:5173
